// Prisma Schema for Minh Hồng Fullstack
// Run: npx prisma generate && npx prisma db push
// Optimized for PostgreSQL (Supabase / Neon / Vercel Postgres)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String
  phone         String   @unique
  password      String
  role          String   @default("CUSTOMER")
  loyaltyPoints Int      @default(0)
  referralCode  String?  @unique
  referredBy    String?
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions        Session[]
  contactRequests ContactRequest[]
  reviews         Review[]
  coupons         Coupon[]
  warranties      Warranty[]
  auditLogs       AuditLog[]

  @@index([phone])
  @@index([referralCode])
  @@index([createdAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model ContactRequest {
  id          String   @id @default(cuid())
  name        String
  phone       String
  service     String   @default("KHAC")
  message     String?
  status      String   @default("PENDING")
  notes       String?
  source      String?
  sourcePath  String?
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?
  userId      String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@index([phone])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([source, createdAt])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  rating    Int
  comment   String
  service   String   @default("KHAC")
  approved  Boolean  @default(false)
  deletedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([approved])
  @@index([createdAt])
  @@index([approved, createdAt])
}

model PricingItem {
  id          String   @id @default(cuid())
  category    String
  name        String
  price       String
  unit        String   @default("VNĐ")
  description String?
  note        String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([active])
  @@index([category, sortOrder])
  @@index([active, category, sortOrder])
}

model Coupon {
  id          String    @id @default(cuid())
  code        String    @unique
  description String
  discount    String
  pointsCost  Int       @default(0)
  usageLimit  Int       @default(1)
  usedCount   Int       @default(0)
  active      Boolean   @default(true)
  expiresAt   DateTime?
  userId      String?
  createdAt   DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([code])
  @@index([userId])
  @@index([active])
  @@index([createdAt])
  @@index([active, createdAt])
}

model Warranty {
  id            String   @id @default(cuid())
  serialNo      String   @unique
  productName   String
  customerName  String
  customerPhone String
  service       String   @default("KHAC")
  startDate     DateTime @default(now())
  endDate       DateTime
  notes         String?
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  userId        String?

  user User? @relation(fields: [userId], references: [id])

  @@index([serialNo])
  @@index([customerPhone])
  @@index([userId])
  @@index([createdAt])
  @@index([endDate])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ip        String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([entity, entityId])
  @@index([action, createdAt])
}

model RateLimitBucket {
  identifier String   @id
  count      Int      @default(0)
  resetAt    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([resetAt])
}

model ChatbotEvent {
  id             String   @id @default(cuid())
  eventType      String
  intent         String?
  service        String?
  sourcePath     String?
  messagePreview String?
  fallbackReason String?
  createdAt      DateTime @default(now())

  @@index([eventType])
  @@index([intent])
  @@index([service])
  @@index([createdAt])
  @@index([eventType, createdAt])
}
